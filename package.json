{
  "name": "etaros",
  "version": "1.2.2",
  "description": "AI sidekick that watches your screen — catches scams, bad deals, and subscription traps in real time",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "gen-icon": "electron scripts/gen-icon.js",
    "gen-dmg-bg": "electron scripts/gen-dmg-bg.js",
    "build:mac:arm": "electron-builder --mac dmg --arm64 --publish never",
    "build:mac:x64": "electron-builder --mac dmg --x64   --publish never",
    "build:mac": "npm run build:mac:arm && sleep 4 && npm run build:mac:x64",
    "build:win": "electron-builder --win --publish never",
    "build:all": "electron-builder --mac --win --publish never",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.1",
    "@sentry/electron": "^7.13.0",
    "@supabase/supabase-js": "^2.106.2",
    "electron-store": "8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8"
  },
  "optionalDependencies": {
    "canvas": "^3.2.3"
  },
  "build": {
    "appId": "com.emirilgin.sidekick",
    "productName": "Etaros",
    "copyright": "Copyright © 2025 Etaros",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "overlay.html",
      "quickpanel.html",
      "logo.png",
      "app.config.js"
    ],
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "identity": null,
      "darkModeSupport": true,
      "protocols": [{ "name": "Etaros", "schemes": ["sidekick"] }],
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "Etaros needs screen access to give you real-time AI advice."
      }
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Etaros",
      "background": "build/dmg-bg.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 155,
          "type": "file"
        },
        {
          "x": 400,
          "y": 155,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "iconSize": 96
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
