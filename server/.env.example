# ── Anthropic ──────────────────────────────────────────────────────────────────
# Your Anthropic API key — users NEVER see this
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — already created via Stripe MCP
STRIPE_PRICE_PRO_MONTHLY=price_1TcSzeKM7Mh7gOJisXOROKtJ
STRIPE_PRICE_PRO_YEARLY=price_1TcSzfKM7Mh7gOJiCtvEYJXR
STRIPE_PRICE_MAX_MONTHLY=price_1TcSzgKM7Mh7gOJiPkvAIq6i
STRIPE_PRICE_MAX_YEARLY=price_1TcSzhKM7Mh7gOJiquyOS3vJ

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Sidekick <hi@yourdomain.com>

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
# Your deployed URL — used in Stripe redirect
APP_URL=https://your-sidekick-server.railway.app

# ── License key signing ─────────────────────────────────────────────────────────
# MUST match licenseSecret in app.config.js exactly — keys won't validate otherwise
# Generate: node -e "require('crypto').randomBytes(32).toString('hex')"
LICENSE_SECRET=your_64_char_hex_secret_here

# ── Model ──────────────────────────────────────────────────────────────────────
# claude-haiku-4-20251001 is cheapest (~$0.0008/message with screenshot)
# claude-sonnet-4-20250514 is smarter but costs more
FREE_MODEL=claude-haiku-4-20251001
PRO_MODEL=claude-sonnet-4-20250514
MAX_MODEL=claude-sonnet-4-20250514
